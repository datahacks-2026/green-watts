# Copy to backend/.env and fill in real values. Never commit .env.

# EIA Open Data
EIA_API_KEY=

# Snowflake (optional; SQLite fallback used if SNOWFLAKE_* unset)
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_WAREHOUSE=
SNOWFLAKE_DATABASE=GRIDGREEN
SNOWFLAKE_SCHEMA=PUBLIC
SNOWFLAKE_ROLE=

# Local fallback DB
SQLITE_PATH=backend/data/gridgreen.sqlite

# CORS — Vercel frontend origin (comma separated)
CORS_ALLOW_ORIGINS=http://localhost:3000

# App
APP_ENV=dev
LOG_LEVEL=INFO

# Limits
MAX_CODE_BYTES=262144

# Default region for stubs
DEFAULT_REGION=CISO

# TTL for grid endpoint caching (seconds)
GRID_CACHE_TTL_S=300

# Rate limit (requests per minute per IP) — applied to heavy endpoints
RATE_LIMIT_PER_MINUTE=60

# Request timeout for heavy endpoints (seconds)
REQUEST_TIMEOUT_S=45

# NOAA (token optional for many endpoints, required for some)
NOAA_TOKEN=

# Gemini (Person B — included so .env stays one source of truth)
GEMINI_API_KEY=

# Weights & Biases (optional, used by Brev workload)
WANDB_API_KEY=
WANDB_PROJECT=gridgreen

# AWS — optional SageMaker Processing (`python -m scripts.sagemaker_processing`)
# Prefer `aws configure` / instance roles; these are only listed for completeness.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_DEFAULT_REGION=us-west-2
SAGEMAKER_ROLE_ARN=
SAGEMAKER_S3_BUCKET=
SAGEMAKER_S3_PREFIX=gridgreen/sagemaker
SAGEMAKER_INSTANCE_TYPE=ml.m5.large
# Databricks (optional — SQL warehouse; use with databricks-sql-connector)
# Host only, e.g. adb-1234567890.12.azuredatabricks.net
DATABRICKS_SERVER_HOSTNAME=
# SQL warehouse HTTP path, e.g. /sql/1.0/warehouses/abcd1234
DATABRICKS_HTTP_PATH=
DATABRICKS_TOKEN=

# Unity Catalog FQN for bronze EIA raw Delta (DLT + bronze notebook; overridable per job)
DATABRICKS_BRONZE_TABLE=gridgreen.raw.eia_raw

# DBFS path for upload_eia_export_to_databricks (absolute path, no dbfs: prefix)
DATABRICKS_DBFS_EXPORT_PATH=/FileStore/gridgreen/eia_hourly_export.csv
